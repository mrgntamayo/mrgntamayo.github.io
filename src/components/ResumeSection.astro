---
import type { TimelineItem } from "../data/site";
import TaskList from "./TaskList.astro";

interface Props {
  id: string;
  title: string;
  items: readonly TimelineItem[];
}

const { id, title, items } = Astro.props;
---

<section class="border-t border-line pt-8">
  <h2 id={id} class="text-2xl font-black tracking-tight text-slate-950">{title}</h2>
  <div class="mt-5 divide-y divide-line">
    {
      items.map((item) => (
        <article class="grid gap-3 py-6 first:pt-0 md:grid-cols-5">
          <div class="text-sm font-bold uppercase tracking-wide text-muted md:col-span-1">{item.time}</div>
          <div class="md:col-span-4">
            <h3 class="text-lg font-black leading-tight text-slate-950">{item.title}</h3>
            {item.place && <p class="mt-1 text-lg text-slate-700">{item.place}</p>}
            <TaskList tasks={item.tasks} class="mt-3 space-y-2 text-slate-700" />
          </div>
        </article>
      ))
    }
  </div>
</section>
