---
import { site, cv } from "../data/site";
import ProfileLinks from "./ProfileLinks.astro";
---

<section class="border-b border-line pb-6">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
      <img
        class="h-28 w-28 rounded-xl border border-line object-cover shadow-sm sm:h-40 sm:w-40"
        src={cv.photo}
        alt={site.title}
      />
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-blueprint">{cv.role}</p>
        <h1 class="mt-2 text-4xl font-black leading-none tracking-tight text-slate-950">{site.title}</h1>
        <p class="mt-3 max-w-2xl text-lg leading-8 text-slate-700">{cv.bio}</p>
      </div>
    </div>
    <ProfileLinks />
  </div>
</section>
